#!/usr/bin/env bash
# idle-down [--days N] [--dry] — spin down agent workspaces the operator hasn't INTERACTED with in >=N days
# (default 7). Rolling cleanup so idle sessions don't hold RAM + burn the account.
#
# "Interacted" = the timestamp of the LAST USER TURN in the session transcript — NOT the file mtime,
# because an account-swap bounce or a resume touches the file without any human input (that false
# signal is exactly what made a naive mtime check wrong). Automated nudges are rare (only AUTOCONTINUE
# workspaces on a swap) and only make a session look MORE recent, i.e. fail-safe (won't wrongly kill).
#
# NEVER downs: main (the home base / control surface), claude-remote workspaces (agent lives on a
# remote box — no local transcript), NOIDLE="yes" descriptors, a pane mid-turn (busy = working now),
# or a session whose transcript was written in the last 6h (recent autonomous activity).
# Transient `agentctl stop` (flush-safe; stays listed — idle != ended). Log: ~/.agents/idle-down.log.
set -uo pipefail
export PATH="$HOME/.local/bin:$PATH"
A="${A:-$HOME/.agents}"; P="$A/projects"; AGENTCTL="$HOME/.local/bin/agentctl"; LOG="$A/idle-down.log"
# shared primitives (ws_get/ws_agents/ws_transcript/fl_agent_alive/ws_busy) — see bin/fleet-lib.sh
FL_SELF="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
# shellcheck source=fleet-lib.sh
. "$FL_SELF/fleet-lib.sh"
FL_SCRIPT=idle-down
DAYS=7; DRY=0
while [ $# -gt 0 ]; do case "$1" in --days) DAYS="${2:?}"; shift 2;; --dry) DRY=1; shift;; *) echo "unknown arg $1"; exit 2;; esac; done
log(){ fl_log "$@"; }
now=$(date +%s); downed=0; kept=0

# last user-turn epoch for a workspace's transcript (empty if none / no file)
last_user_epoch(){ # <jsonl>
  python3 - "$1" <<'PY'
import json,sys,datetime
last=None
try:
    with open(sys.argv[1],encoding='utf-8',errors='ignore') as fh:
        for line in fh:
            if '"user"' not in line: continue
            try: o=json.loads(line)
            except: continue
            if o.get('type')=='user' or o.get('message',{}).get('role')=='user':
                ts=o.get('timestamp')
                if ts: last=ts
except FileNotFoundError: pass
if last:
    print(int(datetime.datetime.fromisoformat(last.replace('Z','+00:00')).timestamp()))
PY
}
# --- liveness + busy: fl_agent_alive / ws_busy (fleet-lib) — the same full recursive proc walk
# session-guard uses (pane_current_command reports `bash` for a healthy agent; tree depth varies by
# isolation tier) and the same "esc to interrupt" footer match (the ONLY reliable busy signal:
# spinner glyphs ✻/✽/✢ persist in idle panes and would false-positive every idle workspace).

[ "$DRY" = 1 ] && echo "idle-down --dry (threshold ${DAYS}d) — nothing will be stopped"
log "=== idle-down scan (threshold ${DAYS}d, dry=$DRY) ==="

while read -r kind name; do
  [ "$name" = main ] && { log "keep main (home base, always exempt)"; kept=$((kept+1)); continue; }
  ag=$(ws_agents "$name")
  [ "$ag" = claude-remote ] && { log "keep $name (remote agent — no local transcript)"; kept=$((kept+1)); continue; }
  [ "$(ws_get "$name" NOIDLE 2>/dev/null)" = yes ] && { log "keep $name (NOIDLE=yes)"; kept=$((kept+1)); continue; }

  f=$(ws_transcript "$name" 2>/dev/null) || f=""

  if ws_busy "$name"; then log "keep $name (pane busy — working now)"; kept=$((kept+1)); continue; fi
  if [ -n "$f" ] && [ -f "$f" ]; then
    m=$(stat -c %Y "$f")
    if [ $(( (now-m)/3600 )) -lt 6 ]; then
      # mtime is only ACTIVITY if the agent is actually alive — a dead agent's transcript keeps a
      # fresh-looking mtime from before it died, and an OOM-killed agent was once kept 19h as
      # "recent activity" on exactly that misread. Process-existence is the truth; session-guard
      # pages for revival.
      if fl_agent_alive "$name"; then
        log "keep $name (transcript written <6h ago — recent activity)"; kept=$((kept+1)); continue
      else
        log "keep $name (transcript mtime fresh but NO AGENT PROCESS — dead, not idle; session-guard pages for revival)"
        kept=$((kept+1)); continue
      fi
    fi
  fi
  u=$(last_user_epoch "$f"); [ -z "$u" ] && { log "keep $name (no user turns recorded — leave to owner)"; kept=$((kept+1)); continue; }
  idle=$(( (now-u)/86400 ))
  if [ "$idle" -ge "$DAYS" ]; then
    if [ "$DRY" = 1 ]; then echo "  WOULD DOWN: $name ($kind) — idle ${idle}d"; log "would down $name (idle ${idle}d)"
    else log "STOP $name (idle ${idle}d >= ${DAYS}d)"; "$AGENTCTL" stop "$name" >>"$LOG" 2>&1 && log "✓ stopped $name"; fi   # transient stop (stays listed), not retire — merely-idle ≠ ended
    downed=$((downed+1))
  else
    [ "$DRY" = 1 ] && echo "  keep: $name ($kind) — idle ${idle}d < ${DAYS}d"
    log "keep $name (idle ${idle}d < ${DAYS}d)"; kept=$((kept+1))
  fi
done < <("$AGENTCTL" status --json 2>/dev/null | python3 -c "import json,sys;[print(w['kind'],w['name']) for w in json.load(sys.stdin) if w['status']=='up']")

log "=== done: ${downed} $([ "$DRY" = 1 ] && echo would-be) down, ${kept} kept ==="
[ "$DRY" = 1 ] && echo "(${downed} would be stopped, ${kept} kept)"
exit 0   # a successful sweep must exit 0 (the trailing `[ "$DRY" = 1 ]` test is
         # false on a real run and would otherwise become the script's status)
