#!/usr/bin/env bash
# agent-profile — resolve a workspace's PROFILE into a composed config directory.
#
# THE CONFIG MODEL (docs/PROFILES.md): ~/.agents is the single source of truth; ~/.claude and any
# other harness dir is a PROJECTION of it. Every workspace resolves through three layers,
# most-specific wins:
#
#     base  <  <profile>  <  workspace descriptor
#
# base applies to everything; a named profile (client/lab/…) is a workspace TYPE; the descriptor
# overrides both. Each layer contributes instructions (AGENTS.md), settings (settings.json), a skill
# subset (SKILLS=), and policy (KIND/SANDBOX/MODEL/REMOTE_CONTROL). Composing them yields a
# per-workspace config dir that becomes that workspace's CLAUDE_CONFIG_DIR — so a client workspace
# and a lab workspace get genuinely different config on one machine.
#
# WHY CREDENTIALS ARE NOT IN HERE (the load-bearing decision, verified against the CLI 2.1.210
# binary + a live auth test, 2026-07-15): Claude Code writes .credentials.json through an atomic
# helper — `uf(path,data,mode)` = write "$path.tmp.<rand>" then RENAME onto $path. A rename REPLACES
# a symlink with a regular file. So the "symlink creds into the config dir" design self-destructs on
# the first OAuth refresh: the workspace silently forks a private credential copy while the account
# dir keeps the STALE refresh token — and refresh tokens rotate, so the account's copy dies. That is
# the dud-credential failure that already cost this fleet two incidents (a real incident: a stale stash was deployed and the CLI zeroed the live file on first refresh).
#   The fix is not a reconciler; it is to never put credentials on this path. The CLI resolves its
# credential store from CLAUDE_SECURESTORAGE_CONFIG_DIR (`iee()`), INDEPENDENTLY of
# CLAUDE_CONFIG_DIR. So: config dir = per-workspace (composed here), credential store = the account
# dir (one real file per account, shared by every workspace on it, exactly as before profiles).
# Nothing to clobber, nothing to reconcile, and a swap moves the credential env var — not this dir.
#
#   agent-profile compose <ws> [--account LABEL]   build/refresh the config dir; print its path
#   agent-profile credstore <ws> [--account LABEL] print the credential-store dir for this workspace
#   agent-profile policy  <ws> KEY                 print one resolved policy value (KIND/MODEL/…)
#   agent-profile list                             available profiles
#   agent-profile show <profile|--workspace ws>    show the resolved config
set -uo pipefail
A="${FLEET_AGENTS_DIR:-$HOME/.agents}"
PROFILES="${FLEET_PROFILES:-$A/profiles}"
SKILLS_SRC="${FLEET_SKILLS:-$A/skills}"
SESSION_STORE="${FLEET_SESSION_STORE:-$HOME/.claude/projects}"
CFG_ROOT="${FLEET_CFG_ROOT:-$A/cfg}"
CONFINED_CFG="${FLEET_CONFINED_CFG:-$A/confined-cfg}"
ACCTS="${ACCTS:-$A/accounts}"
P="$A/projects"

die(){ echo "agent-profile: $*" >&2; exit 1; }

# ---- one KEY from a layer's profile.conf (inline comments stripped) ----
conf_get(){ grep -oP "^$2=\K.*" "$1/profile.conf" 2>/dev/null | head -1 | sed "s/[[:space:]]*#.*//; s/[[:space:]]*$//"; }
ws_profile(){ grep -oP '^PROFILE="?\K[^"]+' "$P/$1.env" 2>/dev/null | head -1; }

# resolve <ws> <KEY> — descriptor > profile > base. SKILLS deliberately does NOT union across
# layers: the most-specific declaration wins outright, so a narrow profile NARROWS instead of
# inheriting base's 'all'.
resolve(){
  local ws="$1" key="$2" v prof
  v=$(grep -oP "^$key=\"?\K[^\"]+" "$P/$ws.env" 2>/dev/null | head -1)
  [ -n "$v" ] && { printf '%s' "$v"; return; }
  prof=$(ws_profile "$ws")
  [ -n "$prof" ] && v=$(conf_get "$PROFILES/$prof" "$key")
  [ -z "$v" ] && v=$(conf_get "$PROFILES/base" "$key")
  printf '%s' "$v"
}

# which account label does this workspace run under (descriptor > fleet-active)
ws_account(){
  local ws="$1" a
  a=$(grep -oP '^ACCOUNT="?\K[^"]+' "$P/$ws.env" 2>/dev/null | head -1)
  [ -n "$a" ] || a=$(cat "$ACCTS/.active" 2>/dev/null || true)
  printf '%s' "$a"
}

ws_kind(){ local k; k=$(resolve "$1" KIND); printf '%s' "${k:-project}"; }

# ---- layers for a workspace: base, then its profile, then the descriptor's own overlay dir ----
layers_of(){
  local ws="$1" prof; prof=$(ws_profile "$ws")
  [ -z "$prof" ] || [ -d "$PROFILES/$prof" ] || die "workspace '$ws' names unknown profile '$prof'"
  local out=("$PROFILES/base"); [ -n "$prof" ] && out+=("$PROFILES/$prof")
  out+=("$P/$ws.d")            # optional per-workspace overlay dir (AGENTS.md/settings.json)
  printf '%s\n' "${out[@]}"
}

# ---- instructions + settings + skills: the parts every KIND shares -------------------------
compose_common(){
  local ws="$1" cfg="$2" copy_skills="$3" seed_existing="$4"; shift 4
  local layers=(); mapfile -t layers < <(layers_of "$ws")
  mkdir -p "$cfg/skills" || die "cannot create $cfg"

  # PRE-EXISTING SETTINGS ARE NOT OURS TO DESTROY — but only where they are genuinely UNMANAGED.
  # A confined workspace's cfg dir predates profiles and can hold live, hand-tuned settings (an
  # autoupdater switch, its own model pin); composing straight over settings.json would silently
  # delete them. Snapshot those ONCE and treat the snapshot as the LOWEST layer: profiles override
  # what they declare, everything else survives, and the snapshot doubles as the undo record.
  #   seed_existing=no for a project's ~/.agents/cfg/<ws>, which compose OWNS end to end. Seeding
  # there would snapshot our own previous OUTPUT, so a key removed from a profile would be resurrected
  # from the last run forever — composition must stay a pure function of the layers.
  if [ "$seed_existing" = yes ]; then
    local seed="$cfg/.settings.pre-profile.json"
    if [ ! -f "$seed" ] && [ -f "$cfg/settings.json" ]; then
      cp -f "$cfg/settings.json" "$seed"
      echo "agent-profile: snapshotted pre-existing settings → $(basename "$seed") (kept as the base layer)" >&2
    fi
    if [ -f "$seed" ]; then
      mkdir -p "$cfg/.seedlayer"; cp -f "$seed" "$cfg/.seedlayer/settings.json"
      layers=("$cfg/.seedlayer" "${layers[@]}")
    fi
  fi

  # 1) AGENTS.md — concatenated overlays. CLAUDE.md is a MIRROR of it (the harness reads CLAUDE.md
  #    from its config dir as user-level instructions); .agents is the source, .claude is the mirror.
  { for l in "${layers[@]}"; do [ -f "$l/AGENTS.md" ] && { cat "$l/AGENTS.md"; echo; }; done; } > "$cfg/AGENTS.md"
  if [ "$copy_skills" = copy ]; then cp -f "$cfg/AGENTS.md" "$cfg/CLAUDE.md"   # confined: no host symlinks survive the namespace
  else ln -sfn AGENTS.md "$cfg/CLAUDE.md"; fi

  # 2) settings.json — deep merge, later layers win.
  python3 - "$cfg/settings.json" "${layers[@]}" <<'PY'
import json, os, sys
out = sys.argv[1]; merged = {}
def deep(a, b):
    for k, v in b.items():
        if isinstance(v, dict) and isinstance(a.get(k), dict): deep(a[k], v)
        else: a[k] = v
for d in sys.argv[2:]:
    p = os.path.join(d, "settings.json")
    if os.path.isfile(p):
        try: deep(merged, json.load(open(p)))
        except Exception: pass
json.dump(merged, open(out, "w"), indent=2)
PY

  # 3) skills — the resolved set only. A confined workspace must COPY (its namespace does not mount
  #    the host, so a symlink into ~/.agents/skills would dangle inside the sandbox).
  find "$cfg/skills" -maxdepth 1 -mindepth 1 \( -type l -o -type d \) -exec rm -rf {} + 2>/dev/null
  local want; want=$(resolve "$ws" SKILLS)
  local srcs=()
  if printf '%s' "$want" | grep -qw all; then
    for s in "$SKILLS_SRC"/*/; do [ -d "$s" ] && srcs+=("$s"); done
  else
    for name in $want; do [ -d "$SKILLS_SRC/$name" ] && srcs+=("$SKILLS_SRC/$name"); done
  fi
  for s in "${srcs[@]:-}"; do
    [ -n "$s" ] && [ -d "$s" ] || continue
    if [ "$copy_skills" = copy ]; then cp -rL "$s" "$cfg/skills/$(basename "$s")" 2>/dev/null
    else ln -sfn "${s%/}" "$cfg/skills/$(basename "$s")"; fi
  done
}

# ---- compose ------------------------------------------------------------------------------
cmd_compose(){
  local ws="$1" acct=""; shift || true
  while [ $# -gt 0 ]; do case "$1" in --account) acct="${2:-}"; shift 2;; *) shift;; esac; done
  [ -f "$P/$ws.env" ] || die "no workspace '$ws'"
  # Fail closed HERE, in the caller's own shell. layers_of() also validates, but it is consumed via
  # `mapfile < <(layers_of ...)` — a SUBSHELL, so its die() exits the subshell and composition would
  # sail on with an empty layer list, silently producing a config with no profile in it.
  local _p; _p=$(ws_profile "$ws")
  [ -z "$_p" ] || [ -d "$PROFILES/$_p" ] || die "workspace '$ws' names unknown profile '$_p'"

  if [ "$(ws_kind "$ws")" = confined ]; then
    # CONFINED: the config dir IS this workspace's isolated cfg (bind-mounted to /config in the bwrap
    # namespace). Compose the SHAREABLE surface into it and touch nothing else: its credentials are
    # its own isolated stash (never an account's) and its session store is deliberately private.
    # This is the confinement wall — profiles must not punch through it.
    local cfg="$CONFINED_CFG/$ws"
    [ -d "$cfg" ] || die "confined workspace '$ws' has no cfg dir ($cfg) — run confined-cfg-sync first"
    compose_common "$ws" "$cfg" copy yes
    printf '%s' "$cfg"; return 0
  fi

  # PROJECT: per-workspace config dir; credentials live in the ACCOUNT (see the header note).
  local cfg="$CFG_ROOT/$ws"
  compose_common "$ws" "$cfg" link no
  [ -d "$A/subagents" ] && ln -sfn "$A/subagents" "$cfg/agents"

  # session store — the one shared physical store, so a swap never forks a conversation.
  ln -sfn "$SESSION_STORE" "$cfg/projects"

  # .claude.json is per-workspace (the CLI derives its path from CLAUDE_CONFIG_DIR and rewrites it
  # via rename — a symlink here would be destroyed, same as credentials). It carries NO rotating
  # secret: onboarding flags, trust map, oauthAccount display metadata. Seed it from the account,
  # and RE-seed whenever the account changes so its oauthAccount never contradicts the live
  # credential (a mismatch is what triggers "logged in as someone else" re-onboarding).
  [ -n "$acct" ] || acct=$(ws_account "$ws")
  if [ -n "$acct" ] && [ -d "$ACCTS/$acct" ]; then
    if [ ! -f "$cfg/.claude.json" ] || [ "$(cat "$cfg/.account" 2>/dev/null || true)" != "$acct" ]; then
      cp -f "$ACCTS/$acct/.claude.json" "$cfg/.claude.json" 2>/dev/null || true
      chmod 600 "$cfg/.claude.json" 2>/dev/null || true
    fi
    printf '%s\n' "$acct" > "$cfg/.account"
  fi
  printf '%s' "$cfg"
}

# credstore <ws> — where this workspace's credentials live. For a project that is the ACCOUNT dir
# (shared, real file, rename-safe). For a confined workspace it is its own isolated cfg. This is the value of
# CLAUDE_SECURESTORAGE_CONFIG_DIR, and it is what identifies a running workspace's account.
cmd_credstore(){
  local ws="$1" acct=""; shift || true
  while [ $# -gt 0 ]; do case "$1" in --account) acct="${2:-}"; shift 2;; *) shift;; esac; done
  if [ "$(ws_kind "$ws")" = confined ]; then printf '%s' "$CONFINED_CFG/$ws"; return 0; fi
  [ -n "$acct" ] || acct=$(ws_account "$ws")
  [ -n "$acct" ] || die "$ws: no ACCOUNT and fleet-active is unset"
  [ -d "$ACCTS/$acct" ] || die "unknown account '$acct'"
  printf '%s' "$ACCTS/$acct"
}

case "${1:-}" in
  compose)   shift; [ $# -ge 1 ] || die "usage: agent-profile compose <ws> [--account L]"; cmd_compose "$@" ;;
  credstore) shift; [ $# -ge 1 ] || die "usage: agent-profile credstore <ws> [--account L]"; cmd_credstore "$@" ;;
  policy)    shift; [ $# -ge 2 ] || die "usage: agent-profile policy <ws> KEY"; resolve "$1" "$2"; echo ;;
  list)      ls -1 "$PROFILES" 2>/dev/null | while read -r p; do [ -f "$PROFILES/$p/profile.conf" ] && echo "$p"; done ;;
  show)      shift
             if [ "${1:-}" = --workspace ]; then ws="${2:?usage: agent-profile show --workspace <ws>}"
               printf '%-16s %s\n' profile "$(ws_profile "$ws")"
               for k in KIND SANDBOX MODEL REMOTE_CONTROL SKILLS; do printf '%-16s %s\n' "$k" "$(resolve "$ws" "$k")"; done
               printf '%-16s %s\n' account "$(ws_account "$ws")"
               printf '%-16s %s\n' credstore "$(cmd_credstore "$ws" 2>/dev/null)"
             else pr="${1:?profile name}"; echo "profile: $pr"; cat "$PROFILES/$pr/profile.conf" 2>/dev/null; fi ;;
  *) echo "usage: agent-profile compose <ws> [--account L] | credstore <ws> | policy <ws> KEY | list | show <profile|--workspace ws>" >&2; exit 2 ;;
esac
