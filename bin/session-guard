#!/usr/bin/env bash
# session-guard — defends against Claude Code transcript loss (known issues: #59248 silent cleanup,
# #49903 account-switch deletion, #29096 no graceful flush, #63015 100%-context stall). Run on a timer.
#
#  1) ARCHIVE — durable rsync snapshot of every account's session transcripts, so a silent retention
#     cleanup or an account-switch deletion can't take the on-disk history with it. (ZFS snapshots only
#     capture what's flushed; this is a second, transcript-scoped copy.)
#  2) STUCK-SESSION ALERT — flag any live workspace at >=95% context or visibly mid-turn for a long
#     time. Those are exactly the sessions whose in-memory transcript would be lost on a hard kill
#     (a real transcript-loss failure). Logged so we can intervene (manual /compact or fresh session) BEFORE a bounce.
#  3) ROUTING GUARD — alert if a fleet agent is not talking to Anthropic directly, or if a config dir
#     it reads has grown a settings `env` block. See the incident note at the guard itself.
#  4) LIVENESS + RESOURCE GUARD — is the agent actually THERE, and is the machine about to kill it?
#     (2026-07-16: the fleet had guards for transcripts, stuck context, rotation and routing — but
#     none for "the agent is simply gone". A workspace agent was OOM-killed at 08:27 and NOTHING noticed
#     for ~19h; idle-down even logged "keep <ws> — recent activity", because its liveness proxy is
#     transcript mtime, which cannot tell a dead agent from a quiet one. Separately, a compute
#     campaign filled the disk with its own scratch and starved itself to death, unremarked.)
set -uo pipefail
A="$HOME/.agents"; ARCH="$A/session-archive"; LOG="$A/session-guard.log"
log(){ echo "[$(date -u +%FT%TZ)] $*" >> "$LOG"; }
mkdir -p "$ARCH"

# alert_main <key> <msg> — throttled to once per ALERT_SECS per key (mirrors account-watch's
# aw_alert_main). The fleet alerts its coordinator, not the human; main triages.
ALERT_SECS="${ALERT_SECS:-21600}"   # 6h — a standing misconfiguration must not re-page every 15min
alert_main(){
  local key="$1" msg="$2" ts="$A/.session-guard-alert.$1" now; now=$(date +%s)
  if [ -f "$ts" ]; then local last; last=$(cat "$ts" 2>/dev/null | tr -cd '0-9')
    [ -n "$last" ] && [ $((now - last)) -lt "$ALERT_SECS" ] && return 0
  fi
  printf '%s\n' "$now" > "$ts"
  "$HOME/.local/bin/agentctl" send main "[session-guard] $msg" >/dev/null 2>&1 || true
}

# 0) shared-store integrity preflight (rebase 2026-07-01): every ACCOUNT profile's projects/ must
# resolve to the shared host store — a diverged copy silently forks sessions on account swap.
# (client-cfg profiles are deliberately isolated and are NOT checked.)
HOST_STORE="$(readlink -f "$HOME/.claude/projects" 2>/dev/null || true)"
# cfg/* are the COMPOSED per-workspace config dirs (PROFILE= workspaces, 2026-07-15). They carry the
# same invariant for the same reason: their projects/ must be the one shared store.
for p in "$A"/accounts/*/projects "$A"/cfg/*/projects; do
  [ -e "$p" ] || continue
  [ "$(readlink -f "$p" 2>/dev/null || true)" = "$HOST_STORE" ] || \
    log "!!! SHARED-STORE VIOLATION: $p does not resolve to ~/.claude/projects — sessions will fork on swap"
done

# 1) archive transcripts from host + every account profile + every confined client
for base in "$HOME/.claude" "$A"/accounts/* "$A"/client-cfg/*; do
  [ -d "$base/projects" ] || continue
  name=$(basename "$base")
  rsync -a --prune-empty-dirs --include='*/' --include='*.jsonl' --exclude='*' \
        "$base/projects/" "$ARCH/$name/" 2>/dev/null || true
done
find "$ARCH" -name '*.jsonl' -mtime +90 -delete 2>/dev/null || true   # bound archive size

# 2) scrollback capture + stuck-session scan across live workspaces.
# The tmux pane scrollback holds the recent VISIBLE conversation — including turns that have NOT been
# flushed to the JSONL yet. Capturing it continuously is our recovery source for a stuck session: even
# if we later must hard-kill it, the recent conversation survives as text here.
command -v tmux >/dev/null || exit 0
SB="$ARCH/_scrollback"; mkdir -p "$SB"
for s in $(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep '^agent-' || true); do
  ws="${s#agent-}"
  pane=$(tmux list-panes -t "$s:main" -F '#{pane_id}' 2>/dev/null | sed -n 2p)
  [ -n "$pane" ] || continue
  tmux capture-pane -p -J -S - -t "$pane" 2>/dev/null > "$SB/$ws.txt" || true   # full scrollback → latest snapshot
  ctx=$(tail -40 "$SB/$ws.txt" 2>/dev/null | grep -oE '[0-9]+% context used' | grep -oE '^[0-9]+' | head -1)
  if [ -n "${ctx:-}" ] && [ "$ctx" -ge 95 ]; then
    cp "$SB/$ws.txt" "$SB/$ws.STUCK.$(date -u +%Y%m%dT%H%M).txt" 2>/dev/null || true   # preserve a stuck snapshot
    log "STUCK-RISK: $ws at ${ctx}% context — scrollback preserved in $SB/$ws.STUCK.* ; /compact or fresh-session BEFORE any bounce/swap/reboot"
    # Alert, don't act. The CLI's own auto-compact handles the normal path and is observed working
    # (main compacted 4x unattended, 2026-07-12/13); firing our own /compact into a live conversation
    # would discard context the agent chose to keep and inject a turn nobody asked for. What actually
    # needs a human/coordinator is the case auto-compact did NOT save. Escalate it; leave the agent be.
    alert_main "stuck-$ws" "STUCK-RISK: workspace '$ws' is at ${ctx}% context and auto-compact has not resolved it. Scrollback is preserved at $SB/$ws.STUCK.*. Do NOT bounce/swap/reboot it before it is compacted or moved to a fresh session — a hard kill loses the unflushed turns."
  fi
done
find "$SB" -name '*.STUCK.*' -mtime +30 -delete 2>/dev/null || true

# 3) ROUTING GUARD (incident 2026-07-15, main): a third-party plugin/tool rewrote a settings.json at
# 01:00 with an `env` block pointing ANTHROPIC_BASE_URL at a local proxy (127.0.0.1:3456) and
# ANTHROPIC_MODEL at a non-Anthropic model. main silently ran on that proxy for hours — the fleet had
# NO signal that an agent had been rerouted off Anthropic. Two cheap, high-value checks:
#   a) live procs: a fleet agent must talk to Anthropic directly (no BASE_URL/MODEL/API-KEY override).
#   b) config dirs: a settings.json `env` block is the injection vector itself — flag it at rest,
#      before the next launch picks it up.
# Detection only: the remedy (which override is legitimate) is a human call. Profile workspaces are
# structurally protected — their settings.json is composed from ~/.agents/profiles each launch — but
# legacy workspaces read the account dir's settings.json directly, so this stays valuable either way.
for pid in $(pgrep -x claude 2>/dev/null); do
  envf="/proc/$pid/environ"; [ -r "$envf" ] || continue
  ws=$(tr '\0' '\n' < "$envf" 2>/dev/null | sed -n 's/^WS_NAME=//p' | head -1)
  [ -n "$ws" ] || continue                      # not a fleet-launched agent — not ours to police
  for var in ANTHROPIC_BASE_URL ANTHROPIC_MODEL ANTHROPIC_AUTH_TOKEN ANTHROPIC_API_KEY; do
    val=$(tr '\0' '\n' < "$envf" 2>/dev/null | sed -n "s/^$var=//p" | head -1)
    [ -n "$val" ] || continue
    case "$var" in ANTHROPIC_AUTH_TOKEN|ANTHROPIC_API_KEY) val="<set>";; esac   # never log a secret
    log "!!! ROUTING OVERRIDE: $ws (pid $pid) has $var=$val — this agent is not on the fleet's normal Anthropic path"
    alert_main "routing-$ws" "ROUTING OVERRIDE on '$ws': its live process has $var=$val. A fleet agent should talk to Anthropic directly; this is how the 2026-07-15 main incident looked (a plugin rerouted it to a local proxy and it ran on a non-Anthropic model unnoticed). Verify this is intended; if not, check that workspace's config dir settings.json for an 'env' block and relaunch."
  done
done
for s in "$HOME"/.claude/settings.json "$A"/accounts/*/settings.json "$A"/cfg/*/settings.json "$A"/client-cfg/*/settings.json; do
  [ -f "$s" ] || continue
  # Only ROUTING keys, not any env block: legitimate fleet settings carry benign env (one client
  # workspace sets DISABLE_AUTOUPDATER). A guard that fires on those trains everyone to ignore it.
  hits=$(python3 -c '
import json,sys
KEYS={"ANTHROPIC_BASE_URL","ANTHROPIC_MODEL","ANTHROPIC_AUTH_TOKEN","ANTHROPIC_API_KEY",
      "ANTHROPIC_SMALL_FAST_MODEL","ANTHROPIC_DEFAULT_HAIKU_MODEL","ANTHROPIC_DEFAULT_OPUS_MODEL",
      "ANTHROPIC_DEFAULT_SONNET_MODEL","CLAUDE_CODE_USE_BEDROCK","CLAUDE_CODE_USE_VERTEX"}
try: d=json.load(open(sys.argv[1]))
except Exception: sys.exit(1)
env=d.get("env") if isinstance(d,dict) else None
if not isinstance(env,dict): sys.exit(1)
# report keys only — an env block can hold a token, and this string is logged + messaged
found=sorted(set(env) & KEYS)
print(",".join(found)); sys.exit(0 if found else 1)' "$s" 2>/dev/null) || continue
  log "!!! SETTINGS ROUTING OVERRIDE: $s env block sets $hits — injected into every agent using this config dir"
  alert_main "settingsenv-$(basename "$(dirname "$s")")" "CONFIG DRIFT: $s has an 'env' block setting $hits, which is injected into every agent that reads this config dir. That is exactly the vector that rerouted an agent to a local proxy. Confirm it is intended, or remove it and relaunch the affected workspaces."
done

# =================================================================================================
# 4) LIVENESS + RESOURCE GUARD (2026-07-16)
#
# Three failures went unnoticed on 2026-07-15 because nothing was watching for them:
#   • a workspace agent was OOM-killed (14.1GB RSS on a 30GB box). Its tmux session stayed up, so
#     every existing check saw a healthy workspace. Dead for ~19h.
#   • idle-down said "keep <ws> — recent activity": its liveness proxy is transcript MTIME, which
#     cannot distinguish a dead agent from a quiet one.
#   • a compute campaign filled the disk with its own scratch and then starved (its own next write
#     failed). rpool hit 99% with nobody told.
# So: check that each up workspace's agent process EXISTS, warn before memory kills it, warn before
# the disk runs out, and report OOM kills after the fact.
# =================================================================================================
LIVE_STATE="$A/.session-guard-liveness"        # debounce: <ws> seen dead once already
MEM_WARN_GB="${MEM_WARN_GB:-8}"                # a fleet agent is normally 0.2-0.5GB; 8 is far out
DISK_MIN_GB="${DISK_MIN_GB:-25}"               # below this, agents start failing to write
mkdir -p "$LIVE_STATE"

# What process proves this workspace's agent is alive? Derived from the descriptor's AGENTS=, so the
# check stays harness-agnostic — a remote workspace's agent IS its ssh, a confined one's is the
# claude-bin inside bwrap. Getting this wrong in either direction is expensive: a false "dead" pages
# a human about a healthy agent, and an over-broad match never reports a real death.
agent_pattern(){
  case "$1" in
    claude)         echo '^(claude|claude-bin|node)$' ;;   # confined execs /opt/claude-bin
    claude-remote)  echo '^(ssh)$' ;;                      # the agent lives on the far end
    codex)          echo '^(codex|node)$' ;;
    opencode)       echo '^(opencode|node|bun)$' ;;
    *)              echo "^($1)$" ;;                       # unknown harness: match its own name
  esac
}
# every pid under a tmux session's panes (the agent is a CHILD of the launcher script, so
# pane_current_command is useless here — it reports `bash` for a perfectly healthy agent).
# FULLY recursive, and it must be: the depth varies by isolation tier, so any fixed depth reports a
# healthy agent as dead. A project agent is 2 levels down (bash → claude); a CONFINED one is 4
# (bash → bwrap → bwrap → claude-bin) because bwrap re-execs itself. Guess the depth and you page a
# human about a perfectly healthy client agent every 15 minutes.
proctree(){ local p="$1" c; echo "$p"; for c in $(pgrep -P "$p" 2>/dev/null); do proctree "$c"; done; }
pane_descendants(){
  local sess="$1" pid
  for pid in $(tmux list-panes -t "$sess:main" -F '#{pane_pid}' 2>/dev/null); do proctree "$pid"; done
}

for f in "$A"/projects/*.env; do
  [ -e "$f" ] || continue
  ws=$(basename "${f%.env}")
  tmux has-session -t "agent-$ws" 2>/dev/null || continue          # down on purpose is not a failure
  agents=$(grep -oP '^AGENTS="?\K[^"]+' "$f" 2>/dev/null | head -1); agents="${agents:-claude}"
  for ag in $agents; do
    pat=$(agent_pattern "$ag"); found=0; hog=""; hogrss=0
    for pid in $(pane_descendants "agent-$ws"); do
      comm=$(cat "/proc/$pid/comm" 2>/dev/null) || continue
      printf '%s' "$comm" | grep -qE "$pat" || continue
      found=1
      rss=$(awk '/VmRSS/{print $2}' "/proc/$pid/status" 2>/dev/null)
      [ -n "$rss" ] && [ "$rss" -gt "$hogrss" ] && { hogrss=$rss; hog=$pid; }
    done

    if [ "$found" = 1 ]; then
      rm -f "$LIVE_STATE/$ws.$ag"
      # MEMORY: warn while there is still time to act. the OOM killer takes
      # the whole tmux scope with it, which is why its pane vanished instead of dropping to a shell.
      # Compare the RAW value and format only for display: rounding to %.1f BEFORE the comparison
      # silently floors everything under 0.05GB to "0.0", so a low threshold could never fire.
      gb=$(awk -v k="$hogrss" 'BEGIN{printf "%.1f", k/1048576}')
      if awk -v k="$hogrss" -v w="$MEM_WARN_GB" 'BEGIN{exit !(k/1048576 >= w)}'; then
        log "!!! MEMORY: $ws ($ag, pid $hog) at ${gb}GB RSS — approaching the OOM killer"
        alert_main "mem-$ws" "MEMORY: workspace '$ws' is holding ${gb}GB RSS (warn >=${MEM_WARN_GB}GB). an OOM kill takes the tmux scope with it — the pane vanishes and nothing notices. Consider checkpointing it and restarting it (agentctl stop $ws && agentctl up $ws) BEFORE the kernel decides."
      fi
      continue
    fi

    # DEAD — but debounce: an agent mid-bash-tool-call can momentarily present no matching process,
    # and a guard that cries wolf gets ignored. Only alert on the SECOND consecutive sighting.
    if [ ! -f "$LIVE_STATE/$ws.$ag" ]; then
      date -u +%FT%TZ > "$LIVE_STATE/$ws.$ag"
      log "liveness: $ws ($ag) has no agent process — re-checking next run before alerting"
      continue
    fi
    log "!!! DEAD AGENT: $ws ($ag) — tmux session is up but no $ag process exists (confirmed twice)"
    alert_main "dead-$ws" "DEAD AGENT: workspace '$ws' looks up (its tmux session exists) but has NO $ag process — confirmed on two consecutive checks. Every session-level check reads this workspace as healthy, and idle-down would keep it (its liveness proxy is transcript mtime, which cannot see a dead agent). Its conversation is safe on disk; revive it with: agentctl stop $ws && agentctl up $ws"
  done
done

# BOX-LEVEL MEMORY FLOOR: per-agent RSS above catches one hog; this catches the AGGREGATE — 15
# max-effort agents at 0.5-2G each plus compute jobs can exhaust the box with no single villain
# (a 400MB headroom probe OOM'd at 24/30Gi used — the box was tight, nobody was huge).
BOX_MEM_MIN_G="${BOX_MEM_MIN_G:-3}"
mem_avail_g=$(awk '/MemAvailable/{printf "%d", $2/1048576}' /proc/meminfo 2>/dev/null)
if [ -n "$mem_avail_g" ] && [ "$mem_avail_g" -lt "$BOX_MEM_MIN_G" ]; then
  top_mem=$(ps -eo rss,comm --sort=-rss 2>/dev/null | awk 'NR>1 && NR<=4 {printf "%s %.1fG; ", $2, $1/1048576}')
  log "!!! BOX MEMORY: only ${mem_avail_g}G available (floor ${BOX_MEM_MIN_G}G) — top: $top_mem"
  alert_main "boxmem" "BOX MEMORY: only ${mem_avail_g}G available (floor ${BOX_MEM_MIN_G}G). Top consumers: $top_mem. The next allocation failure will be whichever process asks first — likely an agent or a compute job, and the OOM killer takes its whole tmux scope."
fi

# STUCK INPUT: an idle agent with text sitting in its ❯ input box is a directive that never fired —
# a bracketed paste whose Enter got swallowed (twice on 2026-07-16: 'keep going autonomously' sat
# for an hour; the agent looked nudged and did nothing). Two consecutive sightings of the SAME text
# = stuck, not mid-typing. Alert with the kick command; never auto-submit — the text might be a
# human's half-typed draft, and pressing Enter on someone's behalf is a decision, not plumbing.
STUCK_STATE="$A/.session-guard-stuckinput"; mkdir -p "$STUCK_STATE"
for f in "$A"/projects/*.env; do
  [ -e "$f" ] || continue
  ws=$(basename "${f%.env}")
  tmux has-session -t "agent-$ws" 2>/dev/null || continue
  pane_txt=$(tmux capture-pane -p -t "agent-$ws:main.2" 2>/dev/null)
  # only when IDLE: a busy agent legitimately holds queued input mid-turn
  echo "$pane_txt" | grep -q "esc to interrupt" && { rm -f "$STUCK_STATE/$ws"; continue; }
  # input box = the LAST ❯ line AND it must sit in the pane's bottom region — scrollback renders
  # past turns as "❯ text" too, and during a relaunch those echoes can be the last ❯ visible
  # (3 of 4 first-day pages were exactly this: stale scrollback read as stuck input).
  # tr -cd '[:print:]' FIRST: an "empty" input line often carries non-ASCII residue — box-drawing
  # borders, NBSP, the cursor block — which ASCII-only [:space:] stripping does not remove, so a
  # bare '❯ ' read as stuck text (9-page storm, 2026-07-16 15:19). Multibyte chars are non-printable
  # byte-wise in the C locale and get dropped here; then require >=3 real chars — a 1-2 char residue
  # is never a directive.
  cur=$(echo "$pane_txt" | tail -6 | grep "❯" | tail -1 | sed 's/.*❯ *//' | tr -cd '[:print:]' | tr -d '[:space:]')
  # the queued-messages hint is UI text, not input
  case "$cur" in ""|Pressuptoedit*) rm -f "$STUCK_STATE/$ws"; continue;; esac
  [ "${#cur}" -ge 3 ] || { rm -f "$STUCK_STATE/$ws"; continue; }
  # key the marker to the PANE PID as well as the text: a bounce replaces the pane, and a marker
  # from the PREVIOUS process must never combine with the new one into a "two consecutive sweeps"
  # page (main's finding, 2026-07-16: markers survived the 14:42 swap and false-paged 3 workspaces)
  pane_pid=$(tmux display-message -p -t "agent-$ws:main.2" '#{pane_pid}' 2>/dev/null)
  txt40=$(printf '%s' "$cur" | head -c 40)
  sig="$txt40 pid=$pane_pid"
  if [ -f "$STUCK_STATE/$ws" ] && [ "$(cat "$STUCK_STATE/$ws" 2>/dev/null)" = "$sig" ]; then
    log "!!! STUCK INPUT: $ws idle with unsubmitted input ('${txt40}…') — two consecutive sweeps"
    alert_main "stuckinput-$ws" "STUCK INPUT: workspace '$ws' is idle with text sitting unsubmitted in its input box ('${txt40}…') across two 15-min sweeps — a swallowed Enter means a directive that never fired (an agent sat idle an hour this way on 2026-07-16). If it is a fleet nudge/directive: fleet-msg kick $ws. If it might be a human's half-typed draft, leave it."
  else
    printf '%s' "$sig" > "$STUCK_STATE/$ws"
  fi
done

# OOM POST-MORTEM: the kernel is the only witness to a kill, and the tmux scope dies with the agent,
# so by the time anyone looks there is no process left to inspect. Surface it while the journal is warm.
if command -v journalctl >/dev/null 2>&1; then
  oom=$(journalctl --user --since "-20min" --no-pager 2>/dev/null | grep -c "killed by the OOM killer" || true)
  if [ "${oom:-0}" -gt 0 ]; then
    log "!!! OOM: the kernel OOM-killed $oom process(es) in the last 20min (see: journalctl --user | grep OOM)"
    alert_main "oomkill" "OOM KILL: the kernel killed $oom process(es) in the last 20 minutes. If a workspace's agent vanished, that is why — the tmux scope dies with it, so the pane disappears rather than dropping to a shell. Check 'agentctl status' for a session that is up with a missing agent pane, and revive it (its conversation is safe on disk)."
  fi
fi

# DISK: agents fail in confusing ways when they cannot write (a transcript write, a tool output, a
# QE charge density). A runaway campaign filled the disk with its own scratch and then starved
# on its own next write — the failure that reports itself as "the science stopped", not "disk full".
# Attribution (main's prevention spec, 2026-07-16): a floor alert that names no consumer sends a
# human hunting; naming the top GROWER (delta vs the last stored depth-1 scan) points at the writer.
# Bounded: depth 1, only runs when an alert is firing, baseline refreshed on each attribution.
DU_ROOT="${DU_ROOT:-$HOME}"
attrib(){
  local base="$A/.session-guard-du.baseline" newf="$A/.session-guard-du.new" out=""
  timeout 110 du -xm --max-depth=1 "$DU_ROOT" 2>/dev/null | sort -k2 > "$newf" || true
  if [ -s "$base" ] && [ -s "$newf" ]; then
    out=$(join -j2 "$base" "$newf" 2>/dev/null | awk '{d=$3-$2; if (d>100) print d, $1}' \
          | sort -rn | head -3 | awk '{printf "%s +%dM; ", $2, $1}')
  fi
  [ -z "$out" ] && out=$(sort -rn "$newf" 2>/dev/null | head -3 | awk '{printf "%s %sM; ", $2, $1}')
  mv -f "$newf" "$base" 2>/dev/null || true
  printf '%s' "$out"
}

# EARLY growth catch: the 186G filled over ~30h and was only caught at 99%. A >=GROW_ALERT_G drop
# between two 15-min runs is a runaway writer — naming it at +20G costs almost nothing to undo
# (stop the writer, destroy the last few snapshots), at 99% it cost a month of rollback.
AVAIL_STATE="$A/.session-guard-avail"; GROW_ALERT_G="${GROW_ALERT_G:-20}"
avail_gb=$(df -BG --output=avail / 2>/dev/null | tail -1 | tr -cd '0-9')
prev_avail=$(tr -cd '0-9' < "$AVAIL_STATE" 2>/dev/null)
[ -n "$avail_gb" ] && printf '%s\n' "$avail_gb" > "$AVAIL_STATE"
if [ -n "$prev_avail" ] && [ -n "$avail_gb" ] && [ $((prev_avail - avail_gb)) -ge "$GROW_ALERT_G" ]; then
  growers=$(attrib)
  log "!!! DISK GROWTH: ${prev_avail}G -> ${avail_gb}G free in one interval; growers: ${growers:-unattributed}"
  alert_main "diskgrow" "DISK GROWTH: free space fell ${prev_avail}G -> ${avail_gb}G in ~15min. Top growers: ${growers:-unattributed}. Caught this early, the cheap fix is stopping the writer and destroying only the last few snapshots (BACKUP.md F8) — at 99% it costs a month of rollback."
fi

if [ -n "$avail_gb" ] && [ "$avail_gb" -lt "$DISK_MIN_GB" ]; then
  pct=$(df --output=pcent / 2>/dev/null | tail -1 | tr -cd '0-9')
  growers=$(attrib)
  log "!!! DISK: only ${avail_gb}GB free on / (${pct}% used) — below the ${DISK_MIN_GB}GB floor; growers: ${growers:-unattributed}"
  alert_main "disk" "DISK: only ${avail_gb}GB free on / (${pct}% used, floor ${DISK_MIN_GB}GB). Top consumers/growers: ${growers:-unattributed}. Agents fail in confusing ways when they cannot write — a campaign filled the disk and starved on its own next write, which looked like 'the science stopped' rather than 'disk full'."
fi

# =================================================================================================
# 5) FAILED-UNIT + CAMPAIGN-STALL SWEEP (stall-sweep prevention spec)
#
# Units fail silently: c009r3-qe sat failed NINE DAYS unseen; logrotate/dpkg-db-backup died at
# midnight on the full disk unseen; idle-down reported failed on a cosmetic exit-status bug and
# nobody noticed either. And an ACTIVE unit can be a corpse: a client campaign died mid-flight
# and read as 'science stopped' for 16h because its service stayed green while its log went silent.
# =================================================================================================
# a) anything in --state=failed, user AND system. Throttle key = the failed SET, so a NEW failure
#    pages immediately even while an old one sits inside the 6h window.
failed_units=$( { systemctl --state=failed --no-legend --plain 2>/dev/null | awk '{print "sys:"$1}'
                  systemctl --user --state=failed --no-legend --plain 2>/dev/null | awk '{print "usr:"$1}'; } | sort )
if [ -n "$failed_units" ]; then
  fkey=$(printf '%s' "$failed_units" | md5sum | cut -c1-10)
  flist=$(echo "$failed_units" | tr '\n' ' ')
  log "!!! FAILED UNITS: $flist"
  alert_main "failedunits-$fkey" "FAILED UNITS: $flist — systemctl [--user] status <unit> for the why, reset-failed after fixing. (Before this sweep a unit sat failed 9 days unseen.)"
fi

# c) FLEET INVARIANTS: every cross-state truth (model state, account state, session uniqueness,
#    credential placement, watcher freshness) asserted in ONE canonical place — bin/fleet-invariants.
#    New "two files disagree" classes get an invariant there, not another inline check here.
#    Throttle key = hash of the violated set, so a NEW violation pages through an old one's window.
inv_out=$("$A/bin/fleet-invariants" 2>&1) || {
  ikey=$(printf '%s' "$inv_out" | md5sum | cut -c1-10)
  log "!!! INVARIANTS: $(printf '%s' "$inv_out" | grep -c '^FAIL') violated"
  printf '%s\n' "$inv_out" | while IFS= read -r l; do log "    $l"; done
  alert_main "invariants-$ikey" "FLEET INVARIANTS VIOLATED: $(printf '%s' "$inv_out" | grep '^FAIL' | tr '\n' ' | ') Run: fleet-invariants (VERBOSE=1) — each failure line says what breaks and how."
}

# b) campaign-stall: a RUNNING compute service whose journal has gone silent. Pattern is
#    configurable; default catches the *-camp / *-qe / *-queue naming convention.
# NB: parenthesized default + `--` on the grep — a pattern that begins with a dash is otherwise
# parsed as a grep OPTION, and the sweep dies silently behind its `|| true`.
COMPUTE_RE="${COMPUTE_UNITS_RE:-(-camp|-qe|-queue)}"
STALL_H="${STALL_H:-2}"
# Per-unit progress-path override ($A/stall-progress.conf, lines: "<unit> <file-or-dir>"): some
# runners log progress to FILES, not the journal (first sweep paged a healthy queue whose
# results.csv had advanced 30min earlier). If the override path shows activity within STALL_H, the
# unit is healthy no matter how silent its journal — a file mtime is progress a journal can't see.
STALL_CONF="${STALL_CONF:-$A/stall-progress.conf}"
progress_fresh(){ # <unit> → 0 if its override path saw writes within STALL_H
  local u="$1" path
  path=$(awk -v u="$u" '$1==u {print $2; exit}' "$STALL_CONF" 2>/dev/null)
  [ -n "$path" ] || return 1
  if [ -d "$path" ]; then
    find "$path" -newermt "-${STALL_H} hours" -print -quit 2>/dev/null | grep -q .
  else
    [ -e "$path" ] && [ $(( now_s - $(stat -c %Y "$path" 2>/dev/null || echo 0) )) -lt $(( STALL_H*3600 )) ]
  fi
}
now_s=$(date +%s)
for scope in "--user" ""; do
  while IFS= read -r u; do
    [ -n "$u" ] || continue
    if progress_fresh "$u"; then continue; fi
    last_s=$(journalctl $scope -u "$u" -n1 -o short-unix --no-pager 2>/dev/null | tail -1 | awk '{print int($1)}')
    [ -n "$last_s" ] && [ "$last_s" -gt 0 ] || continue
    sh=$(( (now_s - last_s) / 3600 ))
    if [ "$sh" -ge "$STALL_H" ]; then
      log "!!! CAMPAIGN STALL: $u is active but journal-silent for ${sh}h"
      alert_main "stall-$u" "CAMPAIGN STALL: $u is active but has logged nothing for ${sh}h (threshold ${STALL_H}h) and has no fresh progress files. If this unit logs to FILES (a shell-redirect ExecStart is journal-silent by construction), add a line to $STALL_CONF: '$u <its-log-or-results-dir>'. A campaign died like this and read as 'science stopped' for 16h. Check: journalctl $scope -u $u -n 30"
    fi
  done < <(systemctl $scope list-units --type=service --state=running --no-legend --plain 2>/dev/null \
           | awk '{print $1}' | grep -E -- "$COMPUTE_RE" || true)
done

# HEARTBEAT — backup-watch attests this file's age daily (the mutual-watchdog pair: this guard
# attests backup-watch via fleet-invariants; nobody is the unwatched watcher). Written LAST so a
# fresh heartbeat means the whole sweep ran, not just started.
date -u +%FT%TZ > "$A/.session-guard-heartbeat"
