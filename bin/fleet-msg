#!/usr/bin/env python3
"""fleet-msg — inter-agent messaging: DIRECT delivery into the recipient's conversation + a durable,
provenance-linked audit trail.

DELIVERY (operator, 2026-07-11 rebuild): a message from agent A to agent B is submitted straight into B's
Claude session as a real turn — the way a user prompt is — so B actually processes and acts on it. No
side-channel inbox to poll (that failed: messages sat unread/invisible; a workspace idled on an unread
kickoff, and the operator never saw replies that only reached his inbox). Delivery = paste into B's claude
pane + Enter. If B is down, the message is queued and flushed into B's conversation on its next launch
(active redelivery, never a poll).

PROVENANCE (the operator addendum): every message is ALSO recorded durably for later analysis — append-only
`log.jsonl` (source of truth) + a queryable SQLite `messages.db`. Each record captures from, to, ts,
full body, and the links to trace it in both conversations: the sender's and each recipient's session
id, delivery status/time, and the msg_id — which is embedded in the delivered turn text, so grepping
the msg_id in the recipient's transcript finds the exact turn where it was processed.

Pane model: each `agent-<name>` tmux session has pane 1 = control shell, pane 2 = claude. Target pane
2. (The earlier bug pasted into the *active* pane = the pane-1 shell — delivered nowhere visible.)
"""
import argparse
import datetime
import fcntl
import glob
import json
import os
import re
import sqlite3
import subprocess
import sys
import time

HOME = os.path.expanduser("~")
ROOT = os.environ.get("FLEET_MSG_ROOT", f"{HOME}/.agents/messages")
LOG = f"{ROOT}/log.jsonl"
DB = f"{ROOT}/messages.db"
PENDING = f"{ROOT}/pending"
DESC = f"{HOME}/.agents/projects"

SCHEMA = """
CREATE TABLE IF NOT EXISTS messages (
    msg_id TEXT, ts TEXT, sender TEXT, sender_session TEXT,
    recipient TEXT, recipient_session TEXT, status TEXT, delivered_ts TEXT, body TEXT,
    PRIMARY KEY (msg_id, recipient)
);
CREATE INDEX IF NOT EXISTS ix_msg_sender ON messages(sender);
CREATE INDEX IF NOT EXISTS ix_msg_recipient ON messages(recipient);
CREATE INDEX IF NOT EXISTS ix_msg_ts ON messages(ts);
"""


def _now():
    return datetime.datetime.now(datetime.timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def _new_id():
    stamp = datetime.datetime.now(datetime.timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    rand = open("/proc/sys/kernel/random/uuid").read().strip().replace("-", "")[:4]
    return f"msg-{stamp}-{rand}"


def _append_log(obj):
    os.makedirs(os.path.dirname(LOG), exist_ok=True)
    with open(LOG, "a") as fh:
        fcntl.flock(fh, fcntl.LOCK_EX)
        fh.write(json.dumps(obj, ensure_ascii=False) + "\n")
        fcntl.flock(fh, fcntl.LOCK_UN)


def _db():
    os.makedirs(ROOT, exist_ok=True)
    db = sqlite3.connect(DB)
    db.executescript(SCHEMA)
    return db


def _session_of(name):
    """The workspace's fixed conversation/session id (SESSION_ID, or legacy RESUME=) — the provenance
    link into that agent's transcript. None for non-workspace senders (system timers)."""
    f = f"{DESC}/{name}.env"
    try:
        txt = open(f).read()
    except OSError:
        return None
    m = re.search(r'SESSION_ID="?([^"\n]+)', txt) or re.search(r'RESUME="?([^"\n]+)', txt)
    return m.group(1) if m else None


def _all_workspaces():
    return sorted(re.split(r"\.env", os.path.basename(f))[0] for f in glob.glob(f"{DESC}/*.env"))


def _resolve(to_raw, sender):
    out = []
    for tok in re.split(r"[,\s]+", to_raw.strip()):
        if not tok:
            continue
        t = tok.lstrip("@").lower()
        if t in ("all", "fleet", "everyone"):
            out += [w for w in _all_workspaces() if w != sender]
        elif t in ("human", "owner", "operator"):
            out.append("main")
        else:
            out.append(tok)
    seen, uniq = set(), []
    for r in out:
        if r not in seen:
            seen.add(r); uniq.append(r)
    return uniq


def _claude_pane(name):
    r = subprocess.run(["tmux", "list-panes", "-t", f"agent-{name}:main", "-F", "#{pane_id}"],
                       capture_output=True, text=True)
    if r.returncode != 0:
        return None
    panes = [p for p in r.stdout.split() if p]
    if not panes:
        return None
    return panes[1] if len(panes) > 1 else panes[0]


def _pane_text(pane):
    r = subprocess.run(["tmux", "capture-pane", "-p", "-J", "-t", pane], capture_output=True, text=True)
    return r.stdout if r.returncode == 0 else ""


# Processes that mean "an agent is running in this pane". A dead pane has ONLY a shell in it —
# run-claude ends with `exec bash`, and an OOM-killed agent leaves the launcher's shell behind.
_AGENT_PROCS = {"claude", "claude-bin", "node", "bun", "codex", "opencode", "ssh", "bwrap"}


def _proctree(pid):
    out = [pid]
    r = subprocess.run(["pgrep", "-P", str(pid)], capture_output=True, text=True)
    for c in r.stdout.split():
        out.extend(_proctree(int(c)))
    return out


def _agent_alive(pane):
    """Is a real agent running in this pane, or is it a bare shell?

    THIS GATE EXISTS BECAUSE OF A LIVE INCIDENT (2026-07-15). Delivery is a bracketed
    paste followed by Enter. That is safe into an agent's input box — but a pane whose agent has died
    has dropped to a SHELL (run-claude ends `exec bash`; an OOM-killed agent leaves the same), and
    there the paste+Enter makes **bash execute the message text as commands**. the dead pane was
    still showing the wreckage:
        msg-20260715T005831Z-3666]: command not found
        bash: syntax error near unexpected token `main'
    A message is arbitrary text from another agent. Executing it as shell in the owner's home
    directory is remote code execution by accident — a body containing `$(...)` or backticks runs.
    So: prove an agent is there before submitting; otherwise queue it (the same path a down
    workspace already takes, flushed on next launch). Nothing is lost, and nothing is executed.

    Deliberately matches the AGENT process, not "any non-shell": during a Bash tool call the pane
    subtree is full of shells, but the agent process is still their parent — so a busy agent stays
    correctly 'alive' and keeps its mid-turn delivery. Erring the other way would silently queue
    messages to healthy agents until their next relaunch.
    """
    r = subprocess.run(["tmux", "display-message", "-p", "-t", pane, "#{pane_pid}"],
                       capture_output=True, text=True)
    if r.returncode != 0 or not r.stdout.strip():
        return False
    for pid in _proctree(int(r.stdout.strip())):
        try:
            with open(f"/proc/{pid}/comm") as fh:
                if fh.read().strip() in _AGENT_PROCS:
                    return True
        except OSError:
            continue
    return False


def _composer(pane):
    """(visible, text) for the ❯ composer line. visible=False means NO composer is rendered at all
    (TUI still booting, resume picker, trust modal, full-screen dialog) — which is NOT the same as
    an empty composer. The old code collapsed the two, so verification was blind during exactly the
    window where Enters get eaten by a dialog (the post-relaunch swallow, 2026-07-16).

    Reads WITH escapes (-e): an EMPTY composer renders a dim placeholder hint ('Try "..."') that a
    plain capture returns as literal text — kick would then re-paste the placeholder as a message.
    Typed/pasted input is never faint, so leading SGR containing param 2 right after ❯ = empty."""
    r = subprocess.run(["tmux", "capture-pane", "-p", "-e", "-J", "-t", pane],
                       capture_output=True, text=True)
    if r.returncode != 0:
        return False, ""
    # Bottom 8 lines only: the real composer renders at the pane bottom. During a boot-time
    # transcript replay a PAST prompt's '❯' higher up would otherwise satisfy the readiness gate
    # before the composer exists (review note on 3e286b4; same class as the guard's scrollback FPs).
    tail = [l for l in r.stdout.splitlines() if l.strip()][-8:]
    for line in reversed(tail):
        if "❯" in line:
            after = line.split("❯", 1)[1]
            plain = re.sub(r"\x1b\[[0-9;]*m", "", after).strip()
            lead = re.match(r"\s*((?:\x1b\[[0-9;]*m)+)", after)
            dim = bool(lead) and any(p == "2"
                                     for seq in re.findall(r"\x1b\[([0-9;]*)m", lead.group(1))
                                     for p in seq.split(";"))
            # Dim alone is NOT enough to call it a placeholder: QUEUED mid-turn input renders dim
            # too (found live — a parked directive read as empty would blind every verify).
            # The placeholder is dim AND hint-shaped; queued real text is dim and arbitrary.
            if dim and re.fullmatch(r'Try "[^"]*"', plain):
                return True, ""
            return True, plain
    return False, ""


def _current_input(pane):
    """Text currently sitting in the ❯ input line (empty string if clear)."""
    return _composer(pane)[1]


def _submit(pane, text):
    """Inject text as a SUBMITTED turn. Returns "submitted", "stuck", or None (nothing pasted).

    History: v1 pasted+Enter'd blind (stranded messages); v2 (2026-07-11) added a fixed 0.8s settle
    + one unverified insurance Enter — still stranded 6 directives on 2026-07-16, all in windows
    where the composer wasn't ready (booting TUI after a fleet swap) or the insurance Enter was
    itself swallowed with nothing re-checking. v3 verifies every step against the composer:

      1. READINESS GATE — never paste until a ❯ composer is rendered. Pasting at a modal/boot
         screen sends the eventual Enter to the dialog, not the composer.
      2. PASTE-ARRIVAL CONFIRM — fire Enter only once the text is visibly IN the composer
         (strictly stronger than any fixed settle delay, and adapts to slow renders).
      3. VERIFIED ENTER LOOP — after each Enter, confirm the composer actually cleared; retry
         with escalating waits. A busy agent queues the message mid-turn (composer clears the
         same way), so idle and busy both verify identically.

    "stuck" (text visibly sitting after all retries) is a distinct outcome ON PURPOSE: the text IS
    in the box, so the caller must NOT queue it for re-delivery (that double-delivers when the
    input-watchdog or a kick later fires it). None = nothing landed — safe to queue."""
    t0 = time.time()
    while not _composer(pane)[0]:                         # 1. readiness gate
        if time.time() - t0 > 25:
            return None
        time.sleep(0.5)
    try:
        subprocess.run(["tmux", "load-buffer", "-b", "fmsg", "-"], input=text.encode(), check=True)
        subprocess.run(["tmux", "paste-buffer", "-p", "-b", "fmsg", "-t", pane], check=True)
        subprocess.run(["tmux", "delete-buffer", "-b", "fmsg"], capture_output=True)
    except subprocess.CalledProcessError:
        return None
    t0 = time.time()
    while time.time() - t0 < 5:                           # 2. paste-arrival confirm
        vis, cur = _composer(pane)
        if vis and cur:
            break
        time.sleep(0.3)
    else:
        vis, cur = _composer(pane)
        if vis and not cur:
            return None                                   # paste never arrived — nothing to strand
    for wait in (0.8, 1.0, 1.5, 2.0, 3.0):                # 3. verified Enter loop
        subprocess.run(["tmux", "send-keys", "-t", pane, "Enter"], capture_output=True)
        time.sleep(wait)
        vis, cur = _composer(pane)
        if vis and not cur:
            return "submitted"
        if not vis:                                       # composer hidden (turn view/re-render):
            time.sleep(1.0)                               # re-check once before trusting it
            vis, cur = _composer(pane)
            if not vis or not cur:
                return "submitted"
    return "stuck"


def _wire(env):
    """The text submitted into the recipient's conversation: attribution + the msg_id (so this exact
    turn is greppable back to the log/DB for provenance) + the message verbatim."""
    return f"[message from {env['from']} | {env['id']}]\n{env['body'].rstrip()}"


def _deliver(name, env, no_submit=False):
    pane = None if no_submit else _claude_pane(name)
    # A pane exists != an agent is listening. If the agent is gone, the pane is a shell and
    # submitting would EXECUTE this message as commands (see _agent_alive). Queue instead.
    if pane and not _agent_alive(pane):
        pane = None
    if pane:
        res = _submit(pane, _wire(env))
        if res == "submitted":
            return "delivered"
        if res == "stuck":
            # The text IS in the recipient's composer, just unsubmitted. Queuing it too would
            # double-deliver once the input-watchdog / a kick fires it. Surface, don't re-queue.
            # BUSY qualifier (production data, 16:07Z swap): for a mid-turn recipient the Enter
            # QUEUES the message yet the queued text keeps rendering in the composer, so the verify
            # loop reads not-cleared — "stuck" on a busy recipient usually means DELIVERED-QUEUED
            # (composer confirmed empty post-turn). Cosmetic: qualify so nobody re-fires it by hand.
            busy = "esc to interrupt" in _pane_text(pane)
            if busy:
                print(f"fleet-msg: NOTE {name}: recipient is mid-turn — message likely QUEUED "
                      f"(composer renders queued text until the turn ends; input-watchdog reconciles). "
                      f"Do not re-send.", file=sys.stderr)
            else:
                print(f"fleet-msg: WARNING {name}: message pasted but Enter did not land after retries "
                      f"— left in composer (input-watchdog will fire it, or: fleet-msg kick {name})",
                      file=sys.stderr)
            return "stuck"
    os.makedirs(PENDING, exist_ok=True)
    with open(f"{PENDING}/{name}.jsonl", "a") as fh:
        fh.write(json.dumps(env, ensure_ascii=False) + "\n")
    return "queued"


def cmd_send(a):
    # Sender identity precedence: explicit --from > FLEET_MSG_FROM (a system script's declared
    # identity, e.g. "system:session-guard" — the provenance standard: every machine-mediated
    # message names the SCRIPT it came from) > the workspace name > bare "system".
    sender = (a.get("from") or os.environ.get("FLEET_MSG_FROM")
              or os.environ.get("WS_NAME") or "system")
    body = _body(a)
    if not body.strip():
        sys.exit("fleet-msg: empty message")
    recipients = _resolve(a["to"], sender)
    if not recipients:
        sys.exit("fleet-msg: no recipients")
    mid, ts = _new_id(), _now()
    sender_session = _session_of(sender)
    db = _db()
    rec = {"id": mid, "ts": ts, "from": sender, "to": recipients, "body": body.rstrip(),
           "sender_session": sender_session, "event": "send", "recipients": {}}
    for r in recipients:
        env = {"id": mid, "ts": ts, "from": sender, "body": body.rstrip()}
        status = _deliver(r, env, no_submit=a.get("no_submit"))
        dts = ts if status == "delivered" else None
        rsess = _session_of(r)
        rec["recipients"][r] = {"status": status, "session": rsess, "delivered_ts": dts}
        db.execute("INSERT OR REPLACE INTO messages(msg_id,ts,sender,sender_session,recipient,"
                   "recipient_session,status,delivered_ts,body) VALUES(?,?,?,?,?,?,?,?,?)",
                   (mid, ts, sender, sender_session, r, rsess, status, dts, body.rstrip()))
    db.commit(); db.close()
    _append_log(rec)
    dv = [r for r, v in rec["recipients"].items() if v["status"] == "delivered"]
    q = [r for r, v in rec["recipients"].items() if v["status"] == "queued"]
    st = [r for r, v in rec["recipients"].items() if v["status"] == "stuck"]
    out = f"{mid}  delivered→ {', '.join(dv) or 'none'}"
    if q:
        out += f"  |  QUEUED (down, flush on resume)→ {', '.join(q)}"
    if st:
        out += f"  |  STUCK-IN-COMPOSER (watchdog will fire)→ {', '.join(st)}"
    print(out)
    return mid


def _body(a):
    b = a.get("body")
    if b is None or b == "":
        return sys.stdin.read() if not sys.stdin.isatty() else ""
    if b.startswith("@"):
        with open(b[1:]) as fh:
            return fh.read()
    return b


def cmd_flush(a):
    name = a.get("name") or os.environ.get("WS_NAME")
    if not name:
        sys.exit("fleet-msg: flush needs a name (or WS_NAME)")
    p = f"{PENDING}/{name}.jsonl"
    if not os.path.exists(p):
        print(f"({name}: nothing queued)")
        return
    pane = _claude_pane(name)
    # An up tmux session with a DEAD agent is the worst case for flush: it would submit EVERY queued
    # message into a bash shell, executing each one in turn (that is what wrecked the dead pane we found).
    # A dead agent is 'still down' as far as delivery is concerned — keep the queue, lose nothing.
    if pane and not _agent_alive(pane):
        print(f"({name}: session is up but its AGENT is dead — leaving "
              f"{sum(1 for _ in open(p))} message(s) queued rather than executing them in its shell. "
              f"Revive it: agentctl stop {name} && agentctl up {name})")
        return
    if not pane:
        print(f"({name}: still down — leaving {sum(1 for _ in open(p))} message(s) queued)")
        return
    msgs = [json.loads(l) for l in open(p) if l.strip()]
    db = _db()
    kept, flushed = [], 0
    for m in msgs:
        res = _submit(pane, _wire(m))
        if res != "submitted":
            # v2 marked every flush delivered and deleted the queue — an unconfirmed submit lost
            # the message entirely. Keep unconfirmed ones queued ("stuck" stays queued too: its
            # text is in the composer, but flush re-wires the envelope so a later flush of the
            # SAME id is idempotent for the reader and provenance stays truthful).
            kept.append(m)
            continue
        flushed += 1
        dts = _now()
        db.execute("UPDATE messages SET status='delivered', delivered_ts=? WHERE msg_id=? AND recipient=?",
                   (dts, m["id"], name))
        _append_log({"id": m["id"], "ts": dts, "from": m["from"], "to": [name],
                     "body": m["body"], "event": "flush-delivered", "recipient_session": _session_of(name)})
        time.sleep(0.5)
    db.commit(); db.close()
    if kept:
        with open(p, "w") as fh:
            for m in kept:
                fh.write(json.dumps(m, ensure_ascii=False) + "\n")
        print(f"flushed {flushed}/{len(msgs)} queued message(s) into {name}'s conversation "
              f"({len(kept)} unconfirmed, kept queued)")
    else:
        os.remove(p)
        print(f"flushed {flushed} queued message(s) into {name}'s conversation")


# TUI render strings that are NOT input — residue the composer reader can misread as stranded text.
# Kicking one submits UI noise as a user turn with user authority ('No response requested.' was once
# auto-submitted into a workspace as if the operator sent it). Matched text is CLEARED, never
# submitted. Substring match, case-sensitive; extend as new render strings surface.
_TUI_ARTIFACTS = (
    "No response requested",
    "Interrupted · What should Claude do instead",
    "ctrl+o to expand",
    "esc to interrupt",
)


def _is_artifact(text):
    return any(s in text for s in _TUI_ARTIFACTS)


def cmd_kick(a):
    """Recover an agent stranded with UNSUBMITTED text in its input (pasted but never submitted —
    the stuck-input bug). Submits what was in the box, WRAPPED in the standard provenance envelope
    ([message from system:<script> | msg-id]) and recorded in the durable log — a watchdog-fired
    submission must never be indistinguishable from a live human Enter (a ghost draft once executed
    with operator authority on exactly that confusion). The envelope also defuses '!'/'/' lines:
    prefixed text can no longer execute as a bash/slash command. Known TUI render artifacts are
    cleared, not submitted."""
    name = a.get("name") or os.environ.get("WS_NAME")
    if not name:
        sys.exit("fleet-msg: kick needs a name")
    src = a.get("as_script") or "kick"
    sender = src if src.startswith("system:") else f"system:{src}"
    pane = _claude_pane(name)
    if not pane:
        print(f"({name}: down — nothing to kick)"); return
    # kick presses Enter on whatever is in the box. If the agent is dead that box is a SHELL PROMPT,
    # and the "stuck input" is a command waiting to run. Never press Enter on a shell for someone.
    if not _agent_alive(pane):
        print(f"({name}: session is up but its AGENT is dead — refusing to press Enter on its shell. "
              f"Revive it: agentctl stop {name} && agentctl up {name})"); return
    cur = _current_input(pane)
    if not cur:
        print(f"({name}: input already clear — nothing stuck)"); return
    if a.get("dry"):
        print(f"{name}: WOULD submit stuck input as {sender}: {cur!r}"); return
    subprocess.run(["tmux", "send-keys", "-t", pane, "C-u"], capture_output=True)  # clear the stranded
    time.sleep(0.4)                                                                # text first
    if _is_artifact(cur):
        print(f"{name}: cleared TUI artifact (not submitted): {cur!r}")
        return
    mid, ts = _new_id(), _now()
    env = {"id": mid, "ts": ts, "from": sender, "body": cur}
    ok = _submit(pane, _wire(env)) == "submitted"
    status = "delivered" if ok else "stuck"
    db = _db()
    db.execute("INSERT OR REPLACE INTO messages(msg_id,ts,sender,sender_session,recipient,"
               "recipient_session,status,delivered_ts,body) VALUES(?,?,?,?,?,?,?,?,?)",
               (mid, ts, sender, None, name, _session_of(name), status,
                ts if ok else None, cur))
    db.commit(); db.close()
    _append_log({"id": mid, "ts": ts, "from": sender, "to": [name], "body": cur,
                 "sender_session": None, "event": "kick",
                 "recipients": {name: {"status": status, "session": _session_of(name),
                                       "delivered_ts": ts if ok else None}}})
    print(f"{name}: {'submitted' if ok else 'FAILED to submit'} stuck input as {sender} "
          f"({mid}): {cur!r}")


def cmd_log(a):
    """Query the durable store. Filter by --from/--to/--since; default tails the most recent."""
    if not os.path.exists(DB):
        print("(no messages yet)")
        return
    db = _db()
    where, params = [], []
    if a.get("from"):
        where.append("sender=?"); params.append(a["from"])
    if a.get("to"):
        where.append("recipient=?"); params.append(a["to"])
    if a.get("since"):
        where.append("ts>=?"); params.append(a["since"])
    q = "SELECT ts,sender,recipient,status,msg_id,body FROM messages"
    if where:
        q += " WHERE " + " AND ".join(where)
    q += " ORDER BY ts DESC LIMIT ?"; params.append(a.get("n") or 20)
    rows = db.execute(q, params).fetchall()
    if a.get("json"):
        cols = ["ts", "sender", "recipient", "status", "msg_id", "body"]
        print(json.dumps([dict(zip(cols, r)) for r in rows], ensure_ascii=False, indent=1))
    else:
        for ts, s, r, st, mid, body in reversed(rows):
            print(f"{ts}  {s:12}→{r:14} {st:9} {mid}  {body[:50].replace(chr(10),' ')}")
    db.close()


def main():
    ap = argparse.ArgumentParser(prog="fleet-msg")
    sub = ap.add_subparsers(dest="cmd", required=True)
    s = sub.add_parser("send")
    s.add_argument("--to", required=True); s.add_argument("--from", dest="from")
    s.add_argument("--no-submit", dest="no_submit", action="store_true")
    s.add_argument("body", nargs="?")
    f = sub.add_parser("flush"); f.add_argument("name", nargs="?")
    k = sub.add_parser("kick"); k.add_argument("name", nargs="?"); k.add_argument("--dry", action="store_true")
    k.add_argument("--as", dest="as_script", help="originating script for the provenance envelope (renders as system:<script>)")
    lg = sub.add_parser("log")
    lg.add_argument("n", nargs="?", type=int); lg.add_argument("--from", dest="from")
    lg.add_argument("--to"); lg.add_argument("--since"); lg.add_argument("--json", action="store_true")
    a = vars(ap.parse_args())
    cmd = a.pop("cmd")
    {"send": lambda: cmd_send(a), "flush": lambda: cmd_flush(a), "kick": lambda: cmd_kick(a),
     "log": lambda: cmd_log(a)}[cmd]()


if __name__ == "__main__":
    main()
