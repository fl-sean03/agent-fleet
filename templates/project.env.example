# Project workspace — full host access, shared session store.
# Copy to ~/.agents/projects/<name>.env  (or use: agentctl new <name> --root PATH --rc "Name" --up)
ROOT="$HOME/work/my-project"       # where the agent lives and works
AGENTS="claude"                    # which harness: claude | codex | opencode | claude-remote
REMOTE_CONTROL="on"                # mobile Remote Control bridge
RC_NAME="My Project"               # name shown in the phone app
AUTOSTART="yes"                    # come back up on reboot
SESSION_ID=""                      # leave EMPTY: agentctl assigns a fixed UUID once, forever
MODEL="claude-opus-4-8"            # descriptor pin — survives every relaunch/swap
# ACCOUNT="account-a"              # omit → the fleet-active account at launch
# AUTOCONTINUE="yes"               # receive post-swap "keep going" nudges
