# Non-Claude harness — the AGENTS field selects the launcher (bin/run-<agent>), so a workspace can
# host any CLI agent. Everything else (tmux, messaging, holds, idle-down) works identically.
ROOT="$HOME/work/codex-project"
AGENTS="codex"                     # → bin/run-codex   (also: opencode → bin/run-opencode)
REMOTE_CONTROL="off"
AUTOSTART="no"
SESSION_ID=""
