# Confined workspace — bubblewrap namespace: sees ONLY its own directory + its own isolated config.
# The host filesystem is NOT MOUNTED (unreadable, not merely denied). Its own credential lineage and
# its own session store. Create with: agentctl new <name> --confined "Full Display Name" --up
# then one interactive login:        agentctl login <name>
ROOT="$HOME/confined/example-confined"
AGENTS="claude"
KIND="confined"
SANDBOX="bwrap"
REMOTE_CONTROL="on"
RC_NAME="Example Confined"
AUTOSTART="yes"
SESSION_ID=""
MODEL="claude-opus-4-8"
